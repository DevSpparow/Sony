#!/bin/bash

# ─── Auto-install FFmpeg if not found ───────────────────────────────────────
if ! command -v ffmpeg &>/dev/null; then
    echo "⚡ FFmpeg not found. Installing static binary..."
    mkdir -p /app/ffmpeg-bin

    wget -q "https://github.com/yt-dlp/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-linux64-gpl.tar.xz" \
         -O /tmp/ffmpeg.tar.xz

    tar -xf /tmp/ffmpeg.tar.xz -C /tmp/
    cp /tmp/ffmpeg-master-latest-linux64-gpl/bin/ffmpeg  /app/ffmpeg-bin/
    cp /tmp/ffmpeg-master-latest-linux64-gpl/bin/ffprobe /app/ffmpeg-bin/
    chmod +x /app/ffmpeg-bin/ffmpeg /app/ffmpeg-bin/ffprobe

    export PATH="/app/ffmpeg-bin:$PATH"
    echo "✅ FFmpeg installed: $(ffmpeg -version | head -1)"
else
    echo "✅ FFmpeg already available: $(ffmpeg -version | head -1)"
fi

# ─── Also export PATH for the Python process ─────────────────────────────────
export PATH="/app/ffmpeg-bin:$PATH"

# ─── Start the bot ───────────────────────────────────────────────────────────
python3 -m MusicSp
